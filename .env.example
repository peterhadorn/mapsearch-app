# MapSearch.app environment variables
# Copy to /var/www/mapsearch/.env and fill in real values

# Database
MAPSEARCH_DATABASE_URL=postgresql://mapsearch:PASSWORD@localhost:5432/mapsearch

# App secret (generate: python3 -c "import secrets; print(secrets.token_hex(32))")
MAPSEARCH_SECRET_KEY=generate-me

# DataForSEO API
DATAFORSEO_LOGIN=your-login
DATAFORSEO_PASSWORD=your-password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SMTP (for password reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@mapsearch.app

# Canonical app URL (used in emails — never from Host header)
APP_BASE_URL=https://mapsearch.app

# Environment (test/production)
MAPSEARCH_ENV=production
